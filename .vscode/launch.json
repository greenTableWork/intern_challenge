    "version": "0.2.0",
    "configurations": [
    
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Debug placement_pytorch_cuda",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/cpp/build_debug/placement_pytorch_cuda",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "preLaunchTask": "Build placement_pytorch_cuda"
        }
    ]
}
